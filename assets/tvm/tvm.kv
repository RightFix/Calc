<TVM>
    name: "tvm_screen"

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "TVM Calculator"
            size_hint_y: None
            height: "56dp"

        ScrollView:
            size_hint_y: 1

            MDBoxLayout:
                orientation: "vertical"
                padding: "16dp"
                spacing: "12dp"
                adaptive_height: True

                MDLabel:
                    text: "Time Value of Money"
                    font_size: "24sp"
                    size_hint_y: None
                    height: "40dp"
                    theme_text_color: "Primary"

                MDLabel:
                    text: "Enter values below:"
                    font_size: "14sp"
                    size_hint_y: None
                    height: "24dp"
                    theme_text_color: "Secondary"

                MDLabel:
                    text: "Present Value / Principal ($)"
                    font_size: "14sp"
                    size_hint_y: None
                    height: "24dp"
                    theme_text_color: "Primary"

                MDTextField:
                    id: pv
                    mode: "outlined"
                    hint_text: "Enter PV or principal amount"
                    size_hint_y: None
                    height: "56dp"
                    input_filter: "float"

                MDLabel:
                    text: "Future Value / Face Value ($)"
                    font_size: "14sp"
                    size_hint_y: None
                    height: "24dp"
                    theme_text_color: "Primary"

                MDTextField:
                    id: fv
                    mode: "outlined"
                    hint_text: "Enter FV or face value"
                    size_hint_y: None
                    height: "56dp"
                    input_filter: "float"

                MDLabel:
                    text: "Interest Rate (%)"
                    font_size: "14sp"
                    size_hint_y: None
                    height: "24dp"
                    theme_text_color: "Primary"

                MDTextField:
                    id: rate
                    mode: "outlined"
                    hint_text: "Enter annual rate %"
                    size_hint_y: None
                    height: "56dp"
                    input_filter: "float"

                MDLabel:
                    text: "Periods / Years"
                    font_size: "14sp"
                    size_hint_y: None
                    height: "24dp"
                    theme_text_color: "Primary"

                MDTextField:
                    id: periods
                    mode: "outlined"
                    hint_text: "Enter number of periods or years"
                    size_hint_y: None
                    height: "56dp"
                    input_filter: "float"

                MDLabel:
                    text: "Cash Flows (for NPV/IRR)"
                    font_size: "14sp"
                    size_hint_y: None
                    height: "24dp"
                    theme_text_color: "Primary"

                MDTextField:
                    id: cashflows
                    mode: "outlined"
                    hint_text: "e.g. -1000, 200, 300, 400"
                    size_hint_y: None
                    height: "56dp"

                MDLabel:
                    text: "Basic Calculations:"
                    font_size: "16sp"
                    size_hint_y: None
                    height: "32dp"
                    theme_text_color: "Primary"

                MDGridLayout:
                    cols: 2
                    spacing: "8dp"
                    size_hint_y: None
                    height: "56dp"

                    MDButton:
                        style: "tonal"
                        on_release: root.calculate_future_value()
                        MDButtonText:
                            text: "Future Value"

                    MDButton:
                        style: "tonal"
                        on_release: root.calculate_present_value()
                        MDButtonText:
                            text: "Present Value"

                MDGridLayout:
                    cols: 2
                    spacing: "8dp"
                    size_hint_y: None
                    height: "56dp"

                    MDButton:
                        style: "tonal"
                        on_release: root.calculate_pmt()
                        MDButtonText:
                            text: "PMT"

                    MDButton:
                        style: "tonal"
                        on_release: root.calculate_nper()
                        MDButtonText:
                            text: "Periods"

                MDGridLayout:
                    cols: 2
                    spacing: "8dp"
                    size_hint_y: None
                    height: "56dp"

                    MDButton:
                        style: "tonal"
                        on_release: root.calculate_rate()
                        MDButtonText:
                            text: "Rate"

                MDLabel:
                    text: "Advanced Calculations:"
                    font_size: "16sp"
                    size_hint_y: None
                    height: "32dp"
                    theme_text_color: "Primary"

                MDGridLayout:
                    cols: 2
                    spacing: "8dp"
                    size_hint_y: None
                    height: "56dp"

                    MDButton:
                        style: "filled"
                        on_release: root.calculate_loan_payment()
                        MDButtonText:
                            text: "Loan Payment"

                    MDButton:
                        style: "filled"
                        on_release: root.calculate_bond_price()
                        MDButtonText:
                            text: "Bond Price"

                MDGridLayout:
                    cols: 2
                    spacing: "8dp"
                    size_hint_y: None
                    height: "56dp"

                    MDButton:
                        style: "filled"
                        on_release: root.calculate_savings()
                        MDButtonText:
                            text: "Savings"

                    MDButton:
                        style: "filled"
                        on_release: root.calculate_npv()
                        MDButtonText:
                            text: "NPV"

                MDButton:
                    style: "filled"
                    on_release: root.calculate_irr()
                    MDButtonText:
                        text: "IRR"

                MDButton:
                    style: "outlined"
                    on_release: root.clear_inputs()
                    MDButtonText:
                        text: "Clear All"

                MDLabel:
                    id: result
                    text: ""
                    font_size: "20sp"
                    size_hint_y: None
                    height: "56dp"
                    halign: "center"
                    theme_text_color: "Primary"

        MDBoxLayout:
            size_hint_y: None
            height: "56dp"
            padding: "8dp"
            spacing: "8dp"

            MDButton:
                style: "tonal"
                size_hint_x: 1
                on_release: root.navigate_to("calculator_screen")
                MDButtonText:
                    text: "Basic"
                    halign: "center"

            MDButton:
                style: "filled"
                size_hint_x: 1
                on_release: root.navigate_to("tvm_screen")
                MDButtonText:
                    text: "TVM"
                    halign: "center"

            MDButton:
                style: "tonal"
                size_hint_x: 1
                on_release: root.navigate_to("assets_val_screen")
                MDButtonText:
                    text: "Assets"
                    halign: "center"