<Calculator>
    name: "calculator_screen"

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Calculator"
            size_hint_y: None
            height: "56dp"

        MDBoxLayout:
            orientation: "vertical"
            padding: "16dp"
            spacing: "4dp"

            MDLabel:
                id: result
                text: ""
                halign: "right"
                font_size: "20sp"
                theme_text_color: "Secondary"
                size_hint_y: None
                height: "24dp"
                text_size: self.width, None

            ScrollView:
                do_scroll_x: "right"
                do_scroll_y: False
                size_hint_y: 1

                MDLabel:
                    id: display
                    text: ""
                    halign: "right"
                    font_size: "40sp"
                    theme_text_color: "Primary"
                    text_size: self.width, None
                    size: self.texture_size

        GridLayout:
            cols: 4
            rows: 5
            spacing: "6dp"
            padding: "8dp"
            size_hint_y: 2

            MDButton:
                style: "outlined"
                on_release: root.clear_display()
                MDButtonText:
                    text: "C"
                    font_size: "22sp"

            MDButton:
                style: "outlined"
                on_release: root.append_text("÷")
                MDButtonText:
                    text: "÷"
                    font_size: "22sp"

            MDButton:
                style: "outlined"
                on_release: root.append_text("×")
                MDButtonText:
                    text: "×"
                    font_size: "22sp"

            MDButton:
                style: "outlined"
                on_release: root.delete_last()
                MDButtonText:
                    text: "⌫"
                    font_size: "22sp"

            MDButton:
                style: "outlined"
                on_release: root.append_text("7")
                MDButtonText:
                    text: "7"
                    font_size: "22sp"

            MDButton:
                style: "outlined"
                on_release: root.append_text("8")
                MDButtonText:
                    text: "8"
                    font_size: "22sp"

            MDButton:
                style: "outlined"
                on_release: root.append_text("9")
                MDButtonText:
                    text: "9"
                    font_size: "22sp"

            MDButton:
                style: "filled"
                on_release: root.append_text("-")
                MDButtonText:
                    text: "-"
                    font_size: "26sp"

            MDButton:
                style: "outlined"
                on_release: root.append_text("4")
                MDButtonText:
                    text: "4"
                    font_size: "22sp"

            MDButton:
                style: "outlined"
                on_release: root.append_text("5")
                MDButtonText:
                    text: "5"
                    font_size: "22sp"

            MDButton:
                style: "outlined"
                on_release: root.append_text("6")
                MDButtonText:
                    text: "6"
                    font_size: "22sp"

            MDButton:
                style: "filled"
                on_release: root.append_text("+")
                MDButtonText:
                    text: "+"
                    font_size: "26sp"

            MDButton:
                style: "outlined"
                on_release: root.append_text("1")
                MDButtonText:
                    text: "1"
                    font_size: "22sp"

            MDButton:
                style: "outlined"
                on_release: root.append_text("2")
                MDButtonText:
                    text: "2"
                    font_size: "22sp"

            MDButton:
                style: "outlined"
                on_release: root.append_text("3")
                MDButtonText:
                    text: "3"
                    font_size: "22sp"

            MDButton:
                style: "filled"
                on_release: root.calculate()
                MDButtonText:
                    text: "="
                    font_size: "26sp"

            MDButton:
                style: "outlined"
                on_release: root.percentage()
                MDButtonText:
                    text: "%"
                    font_size: "22sp"

            MDButton:
                style: "outlined"
                on_release: root.append_text("0")
                MDButtonText:
                    text: "0"
                    font_size: "22sp"

            MDButton:
                style: "outlined"
                on_release: root.append_text(".")
                MDButtonText:
                    text: "."
                    font_size: "22sp"

            MDButton:
                style: "outlined"
                on_release: root.use_answer()
                MDButtonText:
                    text: "Ans"
                    font_size: "18sp"

        MDBoxLayout:
            size_hint_y: None
            height: "56dp"
            padding: "8dp"
            spacing: "8dp"

            MDButton:
                style: "tonal"
                size_hint_x: 1
                on_release: root.navigate_to("tvm_screen")
                MDButtonText:
                    text: "TVM"
                    halign: "center"

            MDButton:
                style: "tonal"
                size_hint_x: 1
                on_release: root.navigate_to("assets_val_screen")
                MDButtonText:
                    text: "Assets"
                    halign: "center"