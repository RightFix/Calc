<AssetsVal>
    name: "assets_val_screen"

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Assets"
            size_hint_y: None
            height: "56dp"

        ScrollView:
            size_hint_y: 1

            MDBoxLayout:
                orientation: "vertical"
                padding: "16dp"
                spacing: "12dp"
                adaptive_height: True

                MDLabel:
                    text: "Assets Valuation"
                    font_size: "24sp"
                    size_hint_y: None
                    height: "40dp"
                    theme_text_color: "Primary"

                MDLabel:
                    text: "Depreciation & Investment Calculations"
                    font_size: "14sp"
                    size_hint_y: None
                    height: "24dp"
                    theme_text_color: "Secondary"

                MDLabel:
                    text: "Asset Cost ($)"
                    font_size: "14sp"
                    size_hint_y: None
                    height: "24dp"
                    theme_text_color: "Primary"

                MDTextField:
                    id: asset_cost
                    mode: "outlined"
                    hint_text: "Enter asset cost"
                    size_hint_y: None
                    height: "56dp"

                MDLabel:
                    text: "Salvage Value ($)"
                    font_size: "14sp"
                    size_hint_y: None
                    height: "24dp"
                    theme_text_color: "Primary"

                MDTextField:
                    id: salvage_value
                    mode: "outlined"
                    hint_text: "Enter salvage value"
                    size_hint_y: None
                    height: "56dp"

                MDLabel:
                    text: "Useful Life (years)"
                    font_size: "14sp"
                    size_hint_y: None
                    height: "24dp"
                    theme_text_color: "Primary"

                MDTextField:
                    id: useful_life
                    mode: "outlined"
                    hint_text: "Enter useful life in years"
                    size_hint_y: None
                    height: "56dp"

                MDLabel:
                    text: "Year (for declining balance)"
                    font_size: "14sp"
                    size_hint_y: None
                    height: "24dp"
                    theme_text_color: "Primary"

                MDTextField:
                    id: year_input
                    mode: "outlined"
                    hint_text: "Enter specific year"
                    size_hint_y: None
                    height: "56dp"

                MDLabel:
                    text: "Gain/Return ($)"
                    font_size: "14sp"
                    size_hint_y: None
                    height: "24dp"
                    theme_text_color: "Primary"

                MDTextField:
                    id: gain
                    mode: "outlined"
                    hint_text: "Enter gain or return amount"
                    size_hint_y: None
                    height: "56dp"

                MDLabel:
                    text: "Discount Rate (%)"
                    font_size: "14sp"
                    size_hint_y: None
                    height: "24dp"
                    theme_text_color: "Primary"

                MDTextField:
                    id: rate
                    mode: "outlined"
                    hint_text: "Enter discount rate %"
                    size_hint_y: None
                    height: "56dp"

                MDLabel:
                    text: "Cash Flows (comma separated)"
                    font_size: "14sp"
                    size_hint_y: None
                    height: "24dp"
                    theme_text_color: "Primary"

                MDTextField:
                    id: cashflows
                    mode: "outlined"
                    hint_text: "e.g. -1000, 200, 300, 400"
                    size_hint_y: None
                    height: "56dp"

                MDLabel:
                    text: "Calculations:"
                    font_size: "16sp"
                    size_hint_y: None
                    height: "32dp"
                    theme_text_color: "Primary"

                MDGridLayout:
                    cols: 2
                    spacing: "8dp"
                    size_hint_y: None
                    height: "56dp"

                    MDButton:
                        style: "tonal"
                        on_release: root.calculate_straight_line()
                        MDButtonText:
                            text: "Straight Line"

                    MDButton:
                        style: "tonal"
                        on_release: root.calculate_declining_balance()
                        MDButtonText:
                            text: "Declining Balance"

                MDGridLayout:
                    cols: 2
                    spacing: "8dp"
                    size_hint_y: None
                    height: "56dp"

                    MDButton:
                        style: "tonal"
                        on_release: root.calculate_roi()
                        MDButtonText:
                            text: "ROI"

                    MDButton:
                        style: "tonal"
                        on_release: root.calculate_npv()
                        MDButtonText:
                            text: "NPV"

                MDButton:
                    style: "tonal"
                    on_release: root.calculate_irr()
                    MDButtonText:
                        text: "IRR"

                MDButton:
                    style: "outlined"
                    on_release: root.clear_inputs()
                    MDButtonText:
                        text: "Clear All"

                MDLabel:
                    id: result
                    text: ""
                    font_size: "20sp"
                    size_hint_y: None
                    height: "48dp"
                    halign: "center"
                    theme_text_color: "Primary"

        MDBoxLayout:
            size_hint_y: None
            height: "56dp"
            padding: "8dp"
            spacing: "8dp"

            MDButton:
                style: "tonal"
                size_hint_x: 1
                on_release: root.navigate_to("calculator_screen")
                MDButtonText:
                    text: "Calc"
                    halign: "center"

            MDButton:
                style: "tonal"
                size_hint_x: 1
                on_release: root.navigate_to("tvm_screen")
                MDButtonText:
                    text: "TVM"
                    halign: "center"

            MDButton:
                style: "filled"
                size_hint_x: 1
                on_release: root.navigate_to("assets_val_screen")
                MDButtonText:
                    text: "Assets"
                    halign: "center"